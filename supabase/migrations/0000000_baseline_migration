-- Realtime policies
DO $$
BEGIN
  IF to_regclass('realtime.messages') IS NOT NULL THEN
    DROP POLICY IF EXISTS realtime_read_changes ON realtime.messages;
    CREATE POLICY realtime_read_changes ON realtime.messages
      FOR SELECT TO authenticated
      USING (topic LIKE 'table:%:changes');
  END IF;
END$$;

-- Storage avatars/competition-images policies on storage.objects
DO $$
BEGIN
  IF to_regclass('storage.objects') IS NOT NULL THEN
    DROP POLICY IF EXISTS avatars_insert ON storage.objects;
    CREATE POLICY avatars_insert ON storage.objects
      FOR INSERT TO public
      WITH CHECK (bucket_id = 'avatars');

    DROP POLICY IF EXISTS avatars_select ON storage.objects;
    CREATE POLICY avatars_select ON storage.objects
      FOR SELECT TO public
      USING (bucket_id = 'avatars');

    DROP POLICY IF EXISTS avatars_update ON storage.objects;
    CREATE POLICY avatars_update ON storage.objects
      FOR UPDATE TO public
      USING (bucket_id = 'avatars');

    DROP POLICY IF EXISTS avatars_delete ON storage.objects;
    CREATE POLICY avatars_delete ON storage.objects
      FOR DELETE TO public
      USING (bucket_id = 'avatars');

    DROP POLICY IF EXISTS comp_images_public_read ON storage.objects;
    CREATE POLICY comp_images_public_read ON storage.objects
      FOR SELECT TO public
      USING (bucket_id = 'competition-images');

    DROP POLICY IF EXISTS comp_images_insert_auth ON storage.objects;
    CREATE POLICY comp_images_insert_auth ON storage.objects
      FOR INSERT TO public
      WITH CHECK (bucket_id = 'competition-images');

    DROP POLICY IF EXISTS comp_images_service_full ON storage.objects;
    CREATE POLICY comp_images_service_full ON storage.objects
      FOR ALL TO public
      USING (bucket_id = 'competition-images');
  END IF;
END$$;

-- Public.tickets policies
DO $$
BEGIN
  IF to_regclass('public.tickets') IS NOT NULL THEN
    DROP POLICY IF EXISTS "Allow anonymous read access to tickets" ON public.tickets;
    CREATE POLICY "Allow anonymous read access to tickets" ON public.tickets
      FOR SELECT TO anon USING (true);

    DROP POLICY IF EXISTS "Allow authenticated read access to tickets" ON public.tickets;
    CREATE POLICY "Allow authenticated read access to tickets" ON public.tickets
      FOR SELECT TO authenticated USING (true);

    DROP POLICY IF EXISTS tickets_insert_authenticated ON public.tickets;
    CREATE POLICY tickets_insert_authenticated ON public.tickets
      FOR INSERT TO authenticated
      WITH CHECK (true);

    DROP POLICY IF EXISTS tickets_all_service_role ON public.tickets;
    CREATE POLICY tickets_all_service_role ON public.tickets
      FOR ALL TO service_role
      USING (true)
      WITH CHECK (true);
  END IF;
END$$;

-- Public.user_transactions policies
DO $$
BEGIN
  IF to_regclass('public.user_transactions') IS NOT NULL THEN
    DROP POLICY IF EXISTS "Allow anonymous read access to user_transactions" ON public.user_transactions;
    CREATE POLICY "Allow anonymous read access to user_transactions" ON public.user_transactions
      FOR SELECT TO anon USING (true);

    DROP POLICY IF EXISTS "Allow authenticated read access to user_transactions" ON public.user_transactions;
    CREATE POLICY "Allow authenticated read access to user_transactions" ON public.user_transactions
      FOR SELECT TO authenticated USING (true);

    DROP POLICY IF EXISTS "Allow service role full access to user_transactions" ON public.user_transactions;
    CREATE POLICY "Allow service role full access to user_transactions" ON public.user_transactions
      FOR ALL TO service_role
      USING (true)
      WITH CHECK (true);

    -- p_tx_select: match canonical_user_id to JWT claim, with SELECT wrapper for initplan
    DROP POLICY IF EXISTS p_tx_select ON public.user_transactions;
    CREATE POLICY p_tx_select ON public.user_transactions
      FOR SELECT TO authenticated
      USING (canonical_user_id = ((SELECT auth.jwt() ->> 'canonical_user_id')));
  END IF;
END$$;

-- Public.canonical_users policies (owner-row)
DO $$
BEGIN
  IF to_regclass('public.canonical_users') IS NOT NULL THEN
    DROP POLICY IF EXISTS own_row_select ON public.canonical_users;
    CREATE POLICY own_row_select ON public.canonical_users
      FOR SELECT TO authenticated
      USING ((uid)::uuid = (SELECT auth.uid()));

    DROP POLICY IF EXISTS own_row_update ON public.canonical_users;
    CREATE POLICY own_row_update ON public.canonical_users
      FOR UPDATE TO authenticated
      USING ((uid)::uuid = (SELECT auth.uid()))
      WITH CHECK ((uid)::uuid = (SELECT auth.uid()));
  END IF;
END$$;

-- Public.realtime messages for competition events
DO $$
BEGIN
  IF to_regclass('realtime.messages') IS NOT NULL THEN
    DROP POLICY IF EXISTS send_competition_events ON realtime.messages;
    CREATE POLICY send_competition_events ON realtime.messages
      FOR INSERT TO authenticated
      WITH CHECK (true);

    DROP POLICY IF EXISTS receive_competition_events ON realtime.messages;
    CREATE POLICY receive_competition_events ON realtime.messages
      FOR SELECT TO authenticated
      USING (
        private = true AND (
          (
            topic LIKE 'competition:%:winners' AND EXISTS (
              SELECT 1 FROM public.winners w
              WHERE w.competition_id = split_part(messages.topic, ':', 2)::uuid
            )
          ) OR (
            topic LIKE 'competition:%:tickets' AND EXISTS (
              SELECT 1 FROM public.tickets t
              WHERE t.competition_id = split_part(messages.topic, ':', 2)::uuid
            )
          )
        )
      );
  END IF;
END$$;

-- Public.competition_winners policies
DO $$
BEGIN
  IF to_regclass('public.competition_winners') IS NOT NULL THEN
    -- Clean duplicates from advisors by re-creating concise set
    DROP POLICY IF EXISTS "Service role can do anything with competition_winners" ON public.competition_winners;
    DROP POLICY IF EXISTS "Service role full access on competition_winners" ON public.competition_winners;
    DROP POLICY IF EXISTS "Authenticated users can read competition_winners" ON public.competition_winners;
    DROP POLICY IF EXISTS "Public can read competition_winners" ON public.competition_winners;
    DROP POLICY IF EXISTS "Public read on competition_winners" ON public.competition_winners;

    CREATE POLICY "Service role full access on competition_winners" ON public.competition_winners
      FOR ALL TO public
      USING ((SELECT auth.role()) = 'service_role');

    CREATE POLICY "Public read on competition_winners" ON public.competition_winners
      FOR SELECT TO public
      USING (true);
  END IF;
END$$;

