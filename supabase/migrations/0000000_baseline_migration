-- Remove duplicate indexes (advisors) - drop safely if both exist
DO $$
BEGIN
  IF EXISTS (
    SELECT 1 FROM pg_indexes WHERE schemaname='public' AND indexname='idx_balance_ledger_canonical'
  ) AND EXISTS (
    SELECT 1 FROM pg_indexes WHERE schemaname='public' AND indexname='idx_balance_ledger_cuid'
  ) THEN
