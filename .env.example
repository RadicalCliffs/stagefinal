# Coinbase Developer Platform (CDP) Configuration
# Get your API key and project ID from: https://portal.cdp.coinbase.com
#
# FRONTEND KEYS (safe to expose, used by CDP React and OnchainKit):
# VITE_CDP_CLIENT_API_KEY is the short alphanumeric Client API Key for OnchainKit (e.g., QEcbaTIUVqvhvAVEh7D0jKXm6hztpgZQ)
# This is REQUIRED for OnchainKit checkout/payment functionality
VITE_CDP_CLIENT_API_KEY=your_client_api_key_here
VITE_CDP_PROJECT_ID=71e24c24-c628-460c-82e3-f830a2b0daf1
#
# BACKEND KEYS (server-side only, never expose to frontend):
# These are used by Netlify functions for server-side CDP SDK operations
# Get these from CDP Portal > API Keys > Create API Key
# CDP_API_KEY_ID=your-api-key-uuid (the "id" field from the JSON)
# CDP_API_KEY_SECRET=your-api-key-private-key (the "privateKey" field from the JSON, base64 encoded)
# CDP_WALLET_SECRET=pem-encoded-private-key (for wallet operations, PKCS8 format)
#
# COINBASE ONRAMP API KEYS (CRITICAL - Required for top-ups):
# These are required by the onramp-init Supabase Edge Function
# Get these from: https://portal.cdp.coinbase.com/access/api
# Used to generate JWT tokens for Coinbase Onramp session initialization
# CDC_CLIENT_API_KEY=your_coinbase_api_key_name (NOT the same as VITE_CDP_CLIENT_API_KEY)
# CDC_SECRET_API_KEY=your_coinbase_api_key_secret
#
# ONCHAINKIT API KEY (server-side, recommended):
# This is the primary OnchainKit API key served from the /api/onchainkit/config endpoint
# Setting this ensures the API key is not bundled into client code
# ONCHAINKIT_API_KEY=your_onchainkit_api_key_here
# Alternative names (checked in order): CDP_CLIENT_API_KEY, VITE_CDP_API_KEY

# OnchainKit Configuration (uses the same CDP project ID)
# This is used for onramp functionality
VITE_ONCHAINKIT_PROJECT_ID=71e24c24-c628-460c-82e3-f830a2b0daf1

# Supabase Configuration
# Required for database operations and type-safe Supabase API wrappers
# Get these from your Supabase project settings → API
# For Netlify: Set these in Site settings → Environment variables
# For local development: Copy this file to .env and fill in the values
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Service Role Key (CRITICAL for Aggressive Mode)
# This gives the frontend FULL admin access to auto-fix schema issues
# Get from: Supabase Dashboard → Settings → API → service_role key
# WARNING: Only use in staging/development - NOT for production
# This enables aggressive mode features:
#   - Auto-create missing tables/columns
#   - Remove blocking constraints
#   - Fix schema errors on the fly
VITE_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Network Configuration
# Set to 'true' for Base Mainnet, anything else (or omit) for Base Sepolia testnet
VITE_BASE_MAINNET=true

# Base Network RPC URLs (optional, defaults to public endpoints)
VITE_BASE_MAINNET_RPC=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Treasury Configuration
VITE_TREASURY_ADDRESS=your_treasury_wallet_address_here

# USDC Contract Address (optional, auto-selected based on network)
# Mainnet: 0x833589fcd6edb6e08f4c7c32d4f71b54bda02913
# Sepolia: 0x036CbD53842c5426634e7929541eC2318f3dCF7e
VITE_USDC_CONTRACT_ADDRESS=

# Commerce Webhook URL (optional)
VITE_COMMERCE_WEBHOOK_URL=

# SendGrid Email Configuration
# Get your API key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=contact@theprize.io

# SendGrid Dynamic Template IDs
# Create templates at: https://mc.sendgrid.com/dynamic-templates
SENDGRID_TEMPLATE_WELCOME=d-3b54b53bcdf744b99cb1f9e7112663a7
# SENDGRID_TEMPLATE_WINNER=your_winner_template_id
# SENDGRID_TEMPLATE_FOMO=your_fomo_template_id
# SENDGRID_TEMPLATE_COMP_LIVE=your_comp_live_template_id

# Base Account SDK Configuration
# These are used for the centralized Base Account SDK integration
# Application name shown in wallet UI
VITE_APP_NAME=The Prize - Win Big with Crypto
# Application logo URL (defaults to /logo.png if not set)
VITE_APP_LOGO_URL=https://theprize.io/logo.png
# Optional: Paymaster URL for gas sponsorship (enables gasless transactions)
# VITE_PAYMASTER_URL=https://paymaster.example.com
